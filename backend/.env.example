# ---------------------------------------------------------------------------
# Creator AI Assistant — backend environment.
# Copy to `.env` and fill in. `.env` is git-ignored; never commit secrets.
# ---------------------------------------------------------------------------

# "local" (development) or "production" (EC2)
ENV=local

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
# Comma-separated. Local: localhost. Production: your EC2 DNS / domain.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated frontend origins allowed to call the API.
# Local Vite dev server runs on :5173. Production: your deployed frontend origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Path to the local clone of the bodhisattvacharyavatara-rails repo.
RAILS_REPO_PATH=/Users/tenkal/webuddhist/obsidian/bodhisattvacharyavatara-rails

# Google Gemini — one API key for both script generation and audio (TTS).
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
